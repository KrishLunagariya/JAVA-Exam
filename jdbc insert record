package jdbc;

import java.sql.*;
/**
 *
 * @author au
 */
public class Insertrecord {
     public static void main(String[] args) {
        try{
            Class.forName("com.mysql.jdbc.Driver");
            String url="jdbc:mysql://localhost:3306/empdata";
            String unm="root";
            String pass="";
            Connection con=DriverManager.getConnection(url,unm,pass);
            
            
            String insertPrepareQry = "insert into emp1 value(?, ?);";
            PreparedStatement pst = con.prepareStatement(insertPrepareQry);
            
            //Assign value
            int eno = 2;
            String ename= "Param";
            pst.setInt(1, eno);
            pst.setString(2, ename);
            
            //Execute
            pst.executeUpdate();
            
            System.out.println("Record inserted");
           }
        catch(Exception e)
        {
            System.out.println(e);
        }
    }
    
}
